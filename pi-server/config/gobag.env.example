GOBAG_HOST=0.0.0.0
GOBAG_PORT=8080
GOBAG_DEVICE_NAME=GO BAG Raspberry Pi
GOBAG_DATA_DIR=/opt/gobag/data
GOBAG_LOG_DIR=/opt/gobag/logs
GOBAG_BACKUP_DIR=/opt/gobag/backups
GOBAG_BASE_URL=
GOBAG_ADMIN_TOKEN=
GOBAG_AUTO_OPEN_BROWSER=1
GOBAG_BROWSER_CMD=
GOBAG_ENABLE_CAMERA=1
GOBAG_CAMERA_CMD=libcamera-still
GOBAG_CAMERA_WIDTH=1280
GOBAG_CAMERA_HEIGHT=720
GOBAG_CAMERA_WARMUP_MS=900
GOBAG_CAMERA_TIMEOUT_S=12
GOBAG_USB_V4L2CTL_CMD=v4l2-ctl
GOBAG_USB_DEVICE_QUERY_TIMEOUT_S=4
GOBAG_USB_PREVIEW_MODE=auto
GOBAG_USB_STREAM_CMD=ffmpeg
GOBAG_USB_STREAM_WIDTH=640
GOBAG_USB_STREAM_HEIGHT=480
GOBAG_USB_STREAM_FPS=10
GOBAG_USB_STREAM_TIMEOUT_S=10
GOBAG_USB_STREAM_PROBE_TIMEOUT_S=3
GOBAG_USB_PREVIEW_WIDTH=640
GOBAG_USB_PREVIEW_HEIGHT=480
GOBAG_USB_PREVIEW_INTERVAL_MS=1200
GOBAG_USB_AUTO_SCAN_INTERVAL_MS=1200
GOBAG_USB_SESSION_INTERVAL_MS=850
GOBAG_USB_SCAN_SKIP_FRAMES=12
